{
  "name": "analyst-console-ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "config": {
    "ignore-scripts": true
  },
  "scripts": {
    "generate:authorities": "node ../scripts/generate-frontend-authorities.mjs",
    "check:authorities": "node ../scripts/generate-frontend-authorities.mjs --check",
    "check:api-client-boundary": "node ../scripts/check-fdp48-api-client-boundary.mjs",
    "check:api-client-boundary:fdp49": "node ../scripts/check-fdp49-api-client-boundary.mjs",
    "check:api-client-boundary:fdp50": "node ../scripts/check-fdp50-api-client-boundary.mjs",
    "check:scope:fdp50": "node ../scripts/check-fdp50-scope.mjs",
    "check:scope:fdp51": "node ../scripts/check-fdp51-scope.mjs",
    "check:scope:fdp52": "node ../scripts/check-fdp52-scope.mjs",
    "check:fdp53-scope": "node ../scripts/check-fdp53-scope.mjs",
    "dev": "npm run generate:authorities && vite --host 127.0.0.1",
    "build": "npm run generate:authorities && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run generate:authorities && vitest run"
  },
  "dependencies": {
    "oidc-client-ts": "3.5.0",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@babel/parser": "7.29.7",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "6.0.2",
    "happy-dom": "20.10.6",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "overrides": {
    "undici": "8.5.0",
    "minimist": "^1.2.8",
    "ws": "^8.21.0"
  }
}
