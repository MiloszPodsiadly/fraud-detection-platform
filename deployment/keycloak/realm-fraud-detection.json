{
  "id": "fraud-detection",
  "realm": "fraud-detection",
  "enabled": true,
  "displayName": "Fraud Detection Local",
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "clients": [
    {
      "clientId": "analyst-console-ui",
      "name": "analyst-console-ui",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": true,
      "redirectUris": [
        "http://localhost:5173/auth/callback",
        "http://localhost:4173/auth/callback"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:4173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/##http://localhost:4173/"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "groups": [
    {
      "name": "fraud-readonly-analyst"
    },
    {
      "name": "fraud-analyst"
    },
    {
      "name": "fraud-reviewer"
    },
    {
      "name": "fraud-ops-admin"
    }
  ],
  "users": [
    {
      "username": "readonly",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "readonly",
          "temporary": false
        }
      ],
      "groups": [
        "fraud-readonly-analyst"
      ]
    },
    {
      "username": "analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "analyst",
          "temporary": false
        }
      ],
      "groups": [
        "fraud-analyst"
      ]
    },
    {
      "username": "reviewer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "reviewer",
          "temporary": false
        }
      ],
      "groups": [
        "fraud-reviewer"
      ]
    },
    {
      "username": "opsadmin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "opsadmin",
          "temporary": false
        }
      ],
      "groups": [
        "fraud-ops-admin"
      ]
    }
  ]
}
