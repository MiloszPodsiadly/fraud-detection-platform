# Committed local runtime fixture template. Values below are for Docker demo/evaluation only.
INTERNAL_AUTH_TOKEN=local-dev-internal-token
# SHA-256 of INTERNAL_AUTH_TOKEN for the optional TOKEN_VALIDATOR override.
INTERNAL_AUTH_TOKEN_SHA256=486c7e8132888f1bbc9cb9165533394615e283500a51bfdfee509e8fe42b869a
INTERNAL_AUTH_JWT_SECRET=local-dev-jwt-service-secret-32bytes
TRUST_AUTHORITY_HMAC_SECRET=local-dev-trust-hmac-secret
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Optional local development tuning.
OLLAMA_MODEL=llama3.2:3b
OLLAMA_KEEP_ALIVE=5m
AUTO_REPLAY_ENABLED=true
AUTO_REPLAY_SOURCE_TYPE=SYNTHETIC
AUTO_REPLAY_MAX_EVENTS=50000
AUTO_REPLAY_THROTTLE_MILLIS=5
AUTO_REPLAY_START_DELAY_MILLIS=15000
